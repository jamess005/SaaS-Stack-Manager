# Copy this file to .env and fill in your local paths.
# .env is gitignored — never commit it.

# Directory containing locally cached model weights
MODELS_DIR=/path/to/your/models

# Override individual model paths if they differ from MODELS_DIR/<name>
# MODEL_PATH=/path/to/your/models/qwen2.5-3b-instruct
# TEACHER_MODEL_PATH=/path/to/your/models/llama-3.1-8b-instruct
# SMALL_MODEL_PATH=/path/to/your/models/qwen2.5-1.5b-instruct

# AMD GPU (ROCm) — set these in your shell before running, not here
# export HSA_OVERRIDE_GFX_VERSION=11.0.0   # RX 7800 XT (gfx1101)
# export HIP_VISIBLE_DEVICES=0
# export ROCR_VISIBLE_DEVICES=0
